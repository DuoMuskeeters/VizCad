  FileBox,
  Loader2,
  Send,
  MoreVertical,
  Trash2,
  Reply,
  ZoomIn,
  ZoomOut,
  RotateCcw,
  Maximize,
  Info,
  HardDrive,
  User,
  Calendar
} from "lucide-react";
