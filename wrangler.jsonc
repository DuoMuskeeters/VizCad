{
  "$schema": "node_modules/wrangler/config-schema.json",
  "placement": { "mode": "smart" },
  "name": "vizcad-ssr",
  "compatibility_date": "2025-09-15",
  "main": "./dist/server/entry.server.js",
  "assets": {
    "directory": "./dist/client",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    "https://viz-cad.com/*"
  ]
}